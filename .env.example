# ── NOTION ────────────────────────────────────────────────────────────────────
# Get this from https://www.notion.so/my-integrations
# 1. Click "New integration"
# 2. Give it a name (e.g. JARVIS)
# 3. Select your workspace
# 4. Copy the "Internal Integration Token" below
NOTION_TOKEN=secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── OLLAMA (local LLM) ────────────────────────────────────────────────────────
# No key needed — just make sure `ollama serve` is running
# Models used:
#   Intent parsing : gemma3:12b        (pull with: ollama pull gemma3:12b)
#   Content gen    : llama3.2:latest   (pull with: ollama pull llama3.2)
OLLAMA_BASE_URL=http://localhost:11434

# ── (OPTIONAL) Claude API — swap in for better content quality ────────────────
# Leave blank to use Ollama only (default / local-first)
ANTHROPIC_API_KEY=

# ── GROQ (fast cloud STT for voice) ───────────────────────────────────────────
# Used for "Hey Jarvis" voice transcription (whisper-large-v3 — much faster than
# local whisper). Free key: https://console.groq.com/keys
# Leave blank to fall back to local faster-whisper.
GROQ_API_KEY=

# ── PERMISSION & AUDIT GATEWAY (§15) ──────────────────────────────────────────
# Global autonomy posture every action is evaluated against:
#   observe   = read-only; proposes actions but executes nothing
#   copilot   = (default) auto read + in-scope write; confirm irreversible/outward/spend
#   autopilot = auto through irreversible; still hard-stops outward/spend
# Change live at runtime: POST /api/gateway/mode {"mode":"autopilot"} or say "set mode autopilot".
JARVIS_AUTONOMY=copilot

# ── MEMORY (§5) ───────────────────────────────────────────────────────────────
# SQLite datastore location (audit log + episodic + semantic memory).
# JARVIS_DB_PATH=./data/jarvis.db
#
# Embedding model for semantic (vector) recall. If absent, recall degrades
# gracefully to keyword search. Enable vectors with: ollama pull nomic-embed-text
JARVIS_EMBED_MODEL=nomic-embed-text
# Model the nightly reflection job uses to distil durable facts.
JARVIS_REFLECT_MODEL=qwen2.5:7b

# ── INTEGRATED OS / PROACTIVE ENGINE (Phase 7) ────────────────────────────────
# Calendar is local-first (SQLite); no Google setup required. Model the calendar
# agent uses to parse "schedule X tomorrow at 3pm" into structured events:
JARVIS_CAL_MODEL=qwen2.5:7b
#
# Proactive scheduler — runs briefings, nightly reflection, and scheduled
# workflows. It seeds two default jobs (Morning briefing @08:00, Nightly
# reflection @03:00) on first start.
#   JARVIS_NO_SCHEDULER=1     disable the scheduler thread entirely
#   JARVIS_SCHEDULER_TICK=30  how often (seconds) it checks for due jobs
#   JARVIS_BRIEFING_NARRATE=1 add a one-line LLM-narrated lead to scheduled briefings
JARVIS_SCHEDULER_TICK=30

# ── MCP TOOL BUS (§7) ─────────────────────────────────────────────────────────
# The universal tool bus. The brain connects (as an MCP *client*) to the servers
# declared in core/mcp/servers.yaml. The official filesystem server is on by
# default, scoped to the workspace sandbox (the §13.1 allowlist). Every tool call
# still passes through the Permission & Audit Gateway with a per-tool risk tier.
# Requires Node/npx on PATH for npx-based servers; the first run downloads them.
#   JARVIS_NO_MCP=1                 disable the tool bus entirely at boot
#   JARVIS_MCP_CONFIG=...           path to an alternate servers.yaml
#   JARVIS_MCP_CONNECT_TIMEOUT=60   seconds to wait for a server to connect
#   JARVIS_MCP_CALL_TIMEOUT=45      seconds to wait for a single tool call
#   JARVIS_MCP_MODEL=qwen2.5:7b     model that picks which tool to call
